root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{kt,kts,java,xml,gradle}]
indent_style = space
indent_size = 4

[*.{yml,yaml,json,md}]
indent_style = space
indent_size = 2

[*.bat]
end_of_line = crlf
indent_style = space
indent_size = 2

[gradlew]
end_of_line = lf
insert_final_newline = true

[gradlew.bat]
end_of_line = crlf
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false
