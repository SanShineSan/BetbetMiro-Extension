version = 1

cloudstream {
    language = "id"
    authors = listOf("BetbetMiro")
    description = "Cineby provider for cineby.sc with homepage rows, URL-based movie/series categories, genre filters, search, detail parsing, TV episode parsing, related titles, iframe fallback, and public HLS/MP4 extraction."

    /**
     * Status int as the following:
     * 0: Down
     * 1: Ok
     * 2: Slow
     * 3: Beta only
     */
    status = 1

    tvTypes = listOf(
        "Movie",
        "TvSeries"
    )

    isCrossPlatform = false
    iconUrl = "https://www.google.com/s2/favicons?domain=cineby.sc&sz=%size%"
}