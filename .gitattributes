# Normalize text files
* text=auto

# Shell / Gradle wrapper must stay LF
*.sh text eol=lf
gradlew text eol=lf

# Windows batch files must stay CRLF
*.bat text eol=crlf
gradlew.bat text eol=crlf

# Source files
*.kt text eol=lf
*.kts text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.py text eol=lf

# Binary files
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.ico binary
*.apk binary
*.zip binary
